<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Sessions horizontal list -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvSessions"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:background="@color/surface_dark"
        android:paddingStart="4dp"
        android:paddingEnd="4dp"/>

    <!-- Status bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="28dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="10dp"
        android:paddingEnd="10dp"
        android:background="#0d1117">
        <TextView
            android:id="@+id/tvStatusDot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="○"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#8b949e"/>
        <TextView
            android:id="@+id/tvStatusLabel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text=" claude  [toca para meta-IA]"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:textColor="#58a6ff"
            android:clickable="true"
            android:focusable="true"/>
        <TextView
            android:id="@+id/tvStatusSession"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:text="[sonnet-4-6]"
            android:textSize="9sp"
            android:fontFamily="monospace"
            android:textColor="#484f58"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="#21262d"/>

    <!-- Chat messages -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"/>

    <!-- Execute preview banner (hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutPreview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#0d1117"
        android:padding="10dp"
        android:visibility="gone">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚀 prompt → claude"
                android:textSize="9sp"
                android:fontFamily="monospace"
                android:textColor="#484f58"/>
            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1"/>
            <TextView
                android:id="@+id/btnPreviewCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✕"
                android:textSize="12sp"
                android:textColor="#484f58"
                android:padding="4dp"
                android:clickable="true"
                android:focusable="true"/>
        </LinearLayout>
        <TextView
            android:id="@+id/tvPreviewPrompt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:textColor="#e6edf3"
            android:textSize="11sp"
            android:fontFamily="monospace"
            android:maxLines="4"
            android:ellipsize="end"
            android:background="#161b22"
            android:padding="8dp"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPreviewEdit"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Editar"
                android:textSize="11sp"
                style="@style/Widget.Material3.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPreviewLaunch"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="2"
                android:layout_marginStart="4dp"
                android:text="Lanzar →"
                android:textSize="11sp"
                android:backgroundTint="#1a3a1a"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Approval banner (hidden by default) -->
    <LinearLayout
        android:id="@+id/layoutApproval"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1a1a2e"
        android:padding="12dp"
        android:visibility="gone">
        <TextView
            android:id="@+id/tvApprovalTool"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#ffcc44"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:maxLines="4"
            android:ellipsize="end"/>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="✅ Aprobar"
                android:backgroundTint="#1a3a1a"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDeny"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="❌ Denegar"
                android:backgroundTint="#3a1a1a"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Input bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="@color/surface_dark">
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNewSession"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_vertical"
            android:layout_marginEnd="4dp"
            android:text="+"
            android:textSize="18sp"
            android:padding="0dp"
            style="@style/Widget.Material3.Button.OutlinedButton"/>
        <EditText
            android:id="@+id/etMessage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Mensaje... (toca label para meta-IA)"
            android:textColor="@color/text_primary"
            android:textColorHint="#888899"
            android:inputType="textMultiLine"
            android:maxLines="3"
            android:background="@android:color/transparent"
            android:paddingStart="8dp"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSend"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="bottom"
            android:layout_marginStart="4dp"
            android:text="→"
            android:textSize="18sp"
            android:padding="0dp"/>
    </LinearLayout>

</LinearLayout>
